{
  "name": "@dev-sujay/omnitracker-server",
  "version": "1.1.1",
  "description": "Full-stack analytics server SDK: Express routers, admin analytics API, Drizzle/MongoDB/Prisma/Memory storage adapters, S3/R2/Local replay adapters, DB migration helpers, and registerOmniTracker one-liner setup.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/drizzle-tables.js",
      "types": "./dist/schema/drizzle-tables.d.ts"
    },
    "./migrations": {
      "import": "./dist/schema/migrations.js",
      "types": "./dist/schema/migrations.d.ts"
    },
    "./storage/drizzle": {
      "import": "./dist/storage/drizzle.js",
      "types": "./dist/storage/drizzle.d.ts"
    },
    "./storage/memory": {
      "import": "./dist/storage/memory.js",
      "types": "./dist/storage/memory.d.ts"
    },
    "./storage/mongodb": {
      "import": "./dist/storage/mongodb.js",
      "types": "./dist/storage/mongodb.d.ts"
    },
    "./storage/prisma": {
      "import": "./dist/storage/prisma.js",
      "types": "./dist/storage/prisma.d.ts"
    },
    "./replay/s3": {
      "import": "./dist/replay/s3.js",
      "types": "./dist/replay/s3.d.ts"
    },
    "./replay/local": {
      "import": "./dist/replay/local.js",
      "types": "./dist/replay/local.d.ts"
    },
    "./replay/r2": {
      "import": "./dist/replay/r2.js",
      "types": "./dist/replay/r2.d.ts"
    }
  },
  "keywords": [
    "analytics",
    "tracker",
    "express",
    "session-replay",
    "middleware",
    "s3",
    "cloudflare-r2",
    "drizzle",
    "mongodb",
    "prisma",
    "admin-dashboard"
  ],
  "author": "Sujay",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "drizzle-orm": ">=0.29.0",
    "mongodb": "^6.0.0",
    "@prisma/client": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.11.0",
    "drizzle-orm": "^0.41.0",
    "express": "^4.21.2",
    "typescript": "^5.3.3"
  }
}
